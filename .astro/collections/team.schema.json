{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "roleEn": {
      "type": "string"
    },
    "photo": {
      "type": "string"
    },
    "bio": {
      "type": "string"
    },
    "bioEn": {
      "type": "string"
    },
    "specializations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "specializationsEn": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "order": {
      "default": 1,
      "type": "number"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "role"
  ]
}