{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "titleEn": {
      "type": "string"
    },
    "service": {
      "type": "string",
      "enum": [
        "implantology",
        "aesthetic",
        "periodontology",
        "facial",
        "aligners"
      ]
    },
    "beforeImage": {
      "type": "string"
    },
    "afterImage": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "descriptionEn": {
      "type": "string"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "service"
  ]
}