---
import type { Lang } from '../utils/i18n';
import { t } from '../utils/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
---

<form id="contact-form" class="contact-form" novalidate>
  <div class="form-row">
    <div class="form-group">
      <label class="form-label" for="cf-name">{tr.contact.name} *</label>
      <input
        id="cf-name"
        name="name"
        type="text"
        class="form-input"
        required
        autocomplete="name"
        placeholder={lang === 'bg' ? 'Иван Иванов' : 'John Doe'}
      />
    </div>
    <div class="form-group">
      <label class="form-label" for="cf-phone">{tr.contact.phone}</label>
      <input
        id="cf-phone"
        name="phone"
        type="tel"
        class="form-input"
        autocomplete="tel"
        placeholder="+359 ..."
      />
    </div>
  </div>

  <div class="form-group">
    <label class="form-label" for="cf-email">{tr.contact.email} *</label>
    <input
      id="cf-email"
      name="email"
      type="email"
      class="form-input"
      required
      autocomplete="email"
      placeholder="example@mail.com"
    />
  </div>

  <div class="form-group">
    <label class="form-label" for="cf-message">{tr.contact.message} *</label>
    <textarea
      id="cf-message"
      name="message"
      class="form-textarea"
      required
      placeholder={lang === 'bg'
        ? 'Опишете Вашето запитване или желания час...'
        : 'Describe your inquiry or preferred appointment time...'}
    ></textarea>
  </div>

  <div id="cf-status" class="form-status" role="alert" aria-live="polite"></div>

  <button type="submit" class="btn btn-primary cf-submit">
    <span class="cf-btn-text">{tr.contact.send}</span>
    <span class="cf-btn-loading" hidden aria-hidden="true">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="spin"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      {tr.contact.sending}
    </span>
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="cf-arrow" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
  </button>
</form>

<style>
.contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.25rem;
}

.cf-submit { align-self: flex-start; min-width: 160px; }

.form-status {
  font-size: 0.9rem;
  border-radius: var(--radius-sm);
  padding: 0;
  transition: var(--transition);
}

.form-status.success {
  background: rgba(34, 197, 94, 0.1);
  border: 1px solid rgba(34, 197, 94, 0.3);
  color: #15803d;
  padding: 0.875rem 1rem;
}

.form-status.error {
  background: rgba(239, 68, 68, 0.1);
  border: 1px solid rgba(239, 68, 68, 0.3);
  color: #dc2626;
  padding: 0.875rem 1rem;
}

.cf-btn-loading { display: flex; align-items: center; gap: 0.5rem; }

.spin {
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@media (max-width: 640px) {
  .form-row { grid-template-columns: 1fr; }
  .cf-submit { width: 100%; justify-content: center; }
}
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  if (!form) throw new Error('Contact form not found');

  const statusEl = document.getElementById('cf-status')!;
  const btnText = form.querySelector('.cf-btn-text') as HTMLElement;
  const btnLoading = form.querySelector('.cf-btn-loading') as HTMLElement;
  const btnArrow = form.querySelector('.cf-arrow') as HTMLElement;
  const submitBtn = form.querySelector('.cf-submit') as HTMLButtonElement;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    btnText.hidden = true;
    btnLoading.hidden = false;
    btnArrow.hidden = true;
    submitBtn.disabled = true;
    statusEl.className = 'form-status';
    statusEl.textContent = '';

    const isBg = document.documentElement.lang === 'bg';
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 15000);

    try {
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
        signal: controller.signal,
      });

      const json = await res.json() as { success?: boolean; error?: string };

      if (res.ok && json.success) {
        statusEl.className = 'form-status success';
        statusEl.textContent = isBg
          ? 'Вашето съобщение беше изпратено успешно! Ще се свържем с Вас скоро.'
          : 'Your message was sent successfully! We will contact you soon.';
        form.reset();
      } else {
        throw new Error(json.error ?? 'Unknown error');
      }
    } catch {
      statusEl.className = 'form-status error';
      statusEl.textContent = isBg
        ? 'Възникна грешка. Моля опитайте отново или ни се обадете.'
        : 'An error occurred. Please try again or call us directly.';
    } finally {
      clearTimeout(timeout);
      btnText.hidden = false;
      btnLoading.hidden = true;
      btnArrow.hidden = false;
      submitBtn.disabled = false;
    }
  });
</script>
