---
import type { Lang } from '../utils/i18n';
import { t, localePath, servicesSlugs } from '../utils/i18n';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = t(lang);
const services = servicesSlugs[lang];

const currentPath = Astro.url.pathname;

function isActive(path: string) {
  return currentPath === path || currentPath.startsWith(path + '/');
}
---

<header class="site-header" id="site-header">
  <div class="container header-inner">
    <!-- Logo -->
    <a href={localePath(lang, '/')} class="logo" aria-label="DreamDent — начало">
      <span class="logo-dream">Dream</span><span class="logo-dent">Dent</span>
      <span class="logo-tagline">{lang === 'bg' ? 'Дентален Център' : 'Dental Center'}</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="main-nav" aria-label="Главна навигация">
      <ul class="nav-list">
        <li>
          <a href={localePath(lang, '/')} class:list={['nav-link', { active: currentPath === '/' || currentPath === '/en' || currentPath === '/en/' }]}>
            {tr.nav.home}
          </a>
        </li>
        <li class="nav-dropdown">
          <button class="nav-link nav-trigger" aria-expanded="false">
            {tr.nav.services}
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </button>
          <div class="dropdown-menu">
            <a href={services.implantology} class="dropdown-item">
              <span class="dropdown-icon">🦷</span>
              {tr.nav.implantology}
            </a>
            <a href={services.aesthetic} class="dropdown-item">
              <span class="dropdown-icon">✨</span>
              {tr.nav.aesthetic}
            </a>
            <a href={services.periodontology} class="dropdown-item">
              <span class="dropdown-icon">🩺</span>
              {tr.nav.periodontology}
            </a>
            <a href={services.facial} class="dropdown-item">
              <span class="dropdown-icon">💆</span>
              {tr.nav.facial}
            </a>
            <a href={services.aligners} class="dropdown-item">
              <span class="dropdown-icon">😁</span>
              {tr.nav.aligners}
            </a>
          </div>
        </li>
        <li>
          <a href={localePath(lang, lang === 'bg' ? '/екип' : '/en/team')}
             class:list={['nav-link', { active: isActive(localePath(lang, '/екип')) }]}>
            {tr.nav.team}
          </a>
        </li>
        <li>
          <a href={localePath(lang, lang === 'bg' ? '/клинични-случаи' : '/en/clinical-cases')}
             class:list={['nav-link', { active: isActive('/клинични-случаи') || isActive('/en/clinical-cases') }]}>
            {tr.nav.cases}
          </a>
        </li>
        <li>
          <a href={localePath(lang, lang === 'bg' ? '/дентален-туризъм' : '/en/dental-tourism')}
             class:list={['nav-link', { active: isActive('/дентален-туризъм') || isActive('/en/dental-tourism') }]}>
            {tr.nav.tourism}
          </a>
        </li>
        <li>
          <a href={localePath(lang, lang === 'bg' ? '/новини' : '/en/news')}
             class:list={['nav-link', { active: isActive('/новини') || isActive('/en/news') }]}>
            {tr.nav.news}
          </a>
        </li>
        <li>
          <a href={localePath(lang, lang === 'bg' ? '/контакти' : '/en/contact')}
             class="btn btn-primary header-cta">
            {tr.nav.contact}
          </a>
        </li>
      </ul>
    </nav>

    <!-- Language Switcher + Mobile Toggle -->
    <div class="header-actions">
      <a href={lang === 'bg' ? '/en/' + Astro.url.pathname.replace(/^\//, '') : Astro.url.pathname.replace(/^\/en/, '') || '/'}
         class="lang-switch"
         aria-label={lang === 'bg' ? 'Switch to English' : 'Превключи на Български'}>
        {lang === 'bg' ? 'EN' : 'BG'}
      </a>

      <button class="mobile-toggle" id="mobile-toggle" aria-label="Отвори меню" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav>
      <a href={localePath(lang, '/')} class="mobile-link">{tr.nav.home}</a>
      <details class="mobile-details">
        <summary class="mobile-link">{tr.nav.services}</summary>
        <div class="mobile-submenu">
          <a href={services.implantology} class="mobile-sublink">{tr.nav.implantology}</a>
          <a href={services.aesthetic} class="mobile-sublink">{tr.nav.aesthetic}</a>
          <a href={services.periodontology} class="mobile-sublink">{tr.nav.periodontology}</a>
          <a href={services.facial} class="mobile-sublink">{tr.nav.facial}</a>
          <a href={services.aligners} class="mobile-sublink">{tr.nav.aligners}</a>
        </div>
      </details>
      <a href={localePath(lang, lang === 'bg' ? '/екип' : '/en/team')} class="mobile-link">{tr.nav.team}</a>
      <a href={localePath(lang, lang === 'bg' ? '/клинични-случаи' : '/en/clinical-cases')} class="mobile-link">{tr.nav.cases}</a>
      <a href={localePath(lang, lang === 'bg' ? '/дентален-туризъм' : '/en/dental-tourism')} class="mobile-link">{tr.nav.tourism}</a>
      <a href={localePath(lang, lang === 'bg' ? '/новини' : '/en/news')} class="mobile-link">{tr.nav.news}</a>
      <a href={localePath(lang, lang === 'bg' ? '/контакти' : '/en/contact')} class="mobile-link mobile-cta">{tr.nav.contact}</a>
    </nav>
  </div>
</header>

<style>
.site-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(250, 247, 242, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid transparent;
  transition: border-color 0.3s, box-shadow 0.3s;
}

.site-header.scrolled {
  border-color: var(--color-border);
  box-shadow: 0 2px 20px rgba(26, 18, 8, 0.08);
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
  gap: 2rem;
}

/* Logo */
.logo {
  display: flex;
  flex-direction: column;
  gap: 0;
  flex-shrink: 0;
}

.logo-dream {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 600;
  color: var(--color-dark);
  letter-spacing: -0.02em;
  line-height: 1;
}

.logo-dent {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  font-weight: 300;
  color: var(--color-gold);
  letter-spacing: 0.05em;
  line-height: 1;
}

.logo-dream, .logo-dent { display: inline; }

.logo-tagline {
  font-family: var(--font-sans);
  font-size: 0.6rem;
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--color-text-muted);
  display: block;
  margin-top: 2px;
}

/* Nav */
.main-nav { display: none; }

.nav-list {
  display: flex;
  align-items: center;
  gap: 0.25rem;
}

.nav-link {
  display: flex;
  align-items: center;
  gap: 0.3rem;
  padding: 0.5rem 0.75rem;
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--color-text-muted);
  border-radius: var(--radius-sm);
  transition: var(--transition);
  background: none;
  cursor: pointer;
}

.nav-link:hover, .nav-link.active {
  color: var(--color-dark);
  background: var(--color-cream-dark);
}

.nav-link.active { color: var(--color-gold-dark); }

.header-cta {
  font-size: 0.8rem !important;
  padding: 0.6rem 1.25rem !important;
  margin-left: 0.5rem;
}

/* Dropdown */
.nav-dropdown { position: relative; }

.dropdown-menu {
  position: absolute;
  top: calc(100% + 0.5rem);
  left: 50%;
  transform: translateX(-50%) translateY(-8px);
  min-width: 220px;
  background: var(--color-white);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: 0.5rem;
  box-shadow: var(--shadow-lg);
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s, transform 0.2s;
  z-index: 200;
}

.nav-dropdown:hover .dropdown-menu,
.nav-dropdown:focus-within .dropdown-menu {
  opacity: 1;
  pointer-events: all;
  transform: translateX(-50%) translateY(0);
}

.dropdown-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.65rem 0.875rem;
  font-size: 0.875rem;
  color: var(--color-text-muted);
  border-radius: var(--radius-sm);
  transition: var(--transition);
}

.dropdown-item:hover {
  background: var(--color-cream);
  color: var(--color-dark);
}

.dropdown-icon { font-size: 1rem; flex-shrink: 0; }

/* Language + Mobile */
.header-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-shrink: 0;
}

.lang-switch {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--color-text-muted);
  padding: 0.35rem 0.65rem;
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  transition: var(--transition);
}

.lang-switch:hover {
  border-color: var(--color-gold);
  color: var(--color-gold);
}

/* Mobile Toggle */
.mobile-toggle {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  width: 32px;
  height: 32px;
  padding: 4px;
}

.mobile-toggle span {
  display: block;
  height: 1.5px;
  background: var(--color-dark);
  border-radius: 2px;
  transition: var(--transition);
  transform-origin: center;
}

.mobile-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(4.5px, 4.5px); }
.mobile-toggle.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.mobile-toggle.open span:nth-child(3) { transform: rotate(-45deg) translate(4.5px, -4.5px); }

/* Mobile Menu */
.mobile-menu {
  display: none;
  flex-direction: column;
  background: var(--color-white);
  border-top: 1px solid var(--color-border);
  padding: 1rem 0 1.5rem;
  max-height: 80vh;
  overflow-y: auto;
}

.mobile-menu.open { display: flex; }

.mobile-link, .mobile-sublink {
  display: block;
  padding: 0.75rem 1.5rem;
  font-size: 0.95rem;
  color: var(--color-text);
  border-bottom: 1px solid transparent;
  transition: var(--transition);
}

.mobile-link:hover { color: var(--color-gold); background: var(--color-cream); }
.mobile-cta { color: var(--color-gold) !important; font-weight: 600; }

.mobile-details summary { list-style: none; cursor: pointer; }
.mobile-details summary::-webkit-details-marker { display: none; }

.mobile-submenu { background: var(--color-cream); }
.mobile-sublink { padding-left: 2.5rem; font-size: 0.9rem; color: var(--color-text-muted); }
.mobile-sublink:hover { color: var(--color-gold); }

/* Responsive */
@media (min-width: 1024px) {
  .main-nav { display: block; }
  .mobile-toggle { display: none; }
}
</style>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('mobile-toggle');
  const menu = document.getElementById('mobile-menu');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  toggle?.addEventListener('click', () => {
    const open = toggle.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(open));
    menu?.classList.toggle('open', open);
    menu?.setAttribute('aria-hidden', String(!open));
  });
</script>
