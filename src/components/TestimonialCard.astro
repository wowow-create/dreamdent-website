---
interface Props {
  text: string;
  author: string;
  delay?: number;
}
const { text, author, delay = 0 } = Astro.props;
---

<figure class="testimonial-card" data-animate="fade-up" data-delay={delay}>
  <div class="testimonial-stars" aria-label="5 stars">
    {'★'.repeat(5)}
  </div>
  <blockquote class="testimonial-text">
    <p>"{text}"</p>
  </blockquote>
  <figcaption class="testimonial-author">— {author}</figcaption>
</figure>

<style>
.testimonial-card {
  background: rgba(250, 247, 242, 0.06);
  border: 1px solid rgba(200, 169, 110, 0.2);
  border-radius: var(--radius-md);
  padding: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.testimonial-stars {
  color: var(--color-gold);
  font-size: 0.9rem;
  letter-spacing: 0.1em;
}

.testimonial-text p {
  font-family: var(--font-serif);
  font-size: 1rem;
  font-style: italic;
  color: rgba(250, 247, 242, 0.85);
  line-height: 1.75;
}

.testimonial-author {
  font-size: 0.8rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  color: var(--color-gold);
  text-transform: uppercase;
}
</style>
