---
interface Review {
  author: string;
  rating: number;
  text: string;
  date: string;
  initials: string;
  avatarColor: string;
}

interface Props {
  lang?: 'bg' | 'en';
}

const { lang = 'bg' } = Astro.props;

const googleMapsUrl = 'https://share.google/kwsknrCuyJWrEkgzr';
const overallRating = 4.9;
const totalReviews = 158;

const reviewsBg: Review[] = [
