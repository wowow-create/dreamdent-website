---
export const prerender = true;
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ContactForm from '../../../components/ContactForm.astro';
const lang = 'en';
---
<BaseLayout title="Implantology — DreamDent Pleven, Bulgaria" description="Dental implants in Pleven, Bulgaria. Dr. Galya Penkova — certified implantologist since 2006. CBCT 3D diagnostics.">
  <div class="page-hero"><div class="container" data-animate="fade-up">
    <div class="breadcrumb"><a href="/en/">Home</a><span class="breadcrumb-sep">/</span><span>Implantology</span></div>
    <span class="section-label">Services</span><h1>Implantology</h1>
    <p class="hero-sub">The modern alternative to missing teeth</p>
  </div></div>
  <section class="section"><div class="container content-grid">
    <article class="content-body" data-animate="fade-up">
      <h2>What are dental implants?</h2>
      <p>Implants are the modern alternative to missing teeth. After a tooth is extracted, the edentulous area begins to age and the bone atrophies if it is not loaded. This leads to shrinkage of the bone ridges and an aging appearance of the face. If implantation is planned soon after tooth extraction, bone aging is stopped.</p>
      <h2>CBCT 3D Diagnostics</h2>
      <p>At DreamDent we use the latest equipment including CBCT (Cone Beam Computed Tomography) — a three-dimensional X-ray that gives us a complete picture of the bone structure before implant placement.</p>
      <h2>Step by Step</h2>
      <ol class="steps-list">
        <li><strong>Examination & Consultation</strong> — X-ray analysis, treatment plan discussion</li>
        <li><strong>CBCT Analysis & Planning</strong> — 3D image and computer planning of implant position</li>
        <li><strong>Implant Placement</strong> — Minimally invasive surgical procedure</li>
        <li><strong>Temporary Teeth</strong> — Made so you can eat and maintain normal social life during healing</li>
        <li><strong>Permanent Teeth</strong> — Impressions taken, permanent teeth fixed. No food restrictions.</li>
      </ol>
      <div class="info-box"><h3>💡 Did you know?</h3><p>At DreamDent, hundreds of implant operations are performed annually, restoring chewing function while achieving perfect aesthetics.</p></div>
    </article>
    <aside class="content-sidebar">
      <div class="sidebar-card" data-animate="fade-left"><h3>Book Appointment</h3><p>Contact us for a free implantology consultation.</p><ContactForm lang={lang} /></div>
      <div class="sidebar-info" data-animate="fade-left" data-delay="100">
        <h4>Dr. Galya Penkova</h4>
        <ul><li>✓ Certified implantologist since 2006</li><li>✓ Specializations in Germany & Italy</li><li>✓ TeethXpress protocols</li><li>✓ Over 2000 implants placed</li></ul>
      </div>
    </aside>
  </div></section>
</BaseLayout>
<style>
.page-hero{background:var(--color-dark);padding:clamp(6rem,12vw,10rem) 0 clamp(3rem,6vw,5rem)}.page-hero h1{color:var(--color-cream);margin-top:0.5rem}.hero-sub{color:rgba(250,247,242,0.6);font-size:1.1rem;margin-top:0.5rem}.content-grid{display:grid;grid-template-columns:1fr 380px;gap:4rem;align-items:start}.content-body h2{font-size:1.5rem;margin:2rem 0 0.75rem}.content-body p{color:var(--color-text-muted);line-height:1.8;margin-bottom:1rem}.steps-list{padding-left:1.5rem;display:flex;flex-direction:column;gap:1rem;margin-block:1rem}.steps-list li{color:var(--color-text-muted);line-height:1.7}.steps-list strong{color:var(--color-dark)}.info-box{background:var(--color-cream-dark);border-left:3px solid var(--color-gold);border-radius:0 var(--radius-md) var(--radius-md) 0;padding:1.5rem;margin-top:2rem}.info-box h3{font-size:1.1rem;margin-bottom:0.5rem}.info-box p{margin:0;font-size:0.9rem}.sidebar-card{background:var(--color-white);border:1px solid var(--color-border);border-radius:var(--radius-md);padding:1.75rem;margin-bottom:1.5rem}.sidebar-card h3{font-size:1.25rem;margin-bottom:0.5rem}.sidebar-card p{font-size:0.875rem;color:var(--color-text-muted);margin-bottom:1.25rem}.sidebar-info{background:var(--color-dark);color:var(--color-cream);border-radius:var(--radius-md);padding:1.5rem}.sidebar-info h4{font-family:var(--font-serif);font-size:1.1rem;color:var(--color-gold);margin-bottom:1rem}.sidebar-info ul{display:flex;flex-direction:column;gap:0.5rem}.sidebar-info li{font-size:0.875rem;color:rgba(250,247,242,0.8)}
@media(max-width:900px){.content-grid{grid-template-columns:1fr}}
</style>
