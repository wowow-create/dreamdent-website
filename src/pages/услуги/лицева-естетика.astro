---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
const lang = 'bg';
---
<BaseLayout title="Лицева естетика — Филъри, ботокс, плазмолифтинг — DreamDent" description="Лицева естетика в Плевен. Хиалуронови филъри, ботокс, плазмолифтинг. Д-р Галя Пенкова.">
  <div class="page-hero"><div class="container" data-animate="fade-up">
    <div class="breadcrumb"><a href="/">Начало</a><span class="breadcrumb-sep">/</span><span>Лицева естетика</span></div>
    <span class="section-label">Услуги</span><h1>Лицева естетика</h1>
    <p class="hero-sub">Физическото и психическото здраве са неразривно свързани</p>
  </div></div>
  <section class="section"><div class="container content-grid">
    <article class="content-body" data-animate="fade-up">
      <h2>За лицевата естетика</h2>
      <p>Физическото и психичното здраве на човека са неразривно свързани. Начинът по който изглежда лицето — изражение, мимика, свежест имат важно значение при контакта с хората, които ни обкръжават, и начина по който ни възприемат. Всичко това оказва огромно влияние върху нашето самочувствие.</p>
      <h2>Нашите услуги</h2>
      <ul class="service-list">
        <li><strong>Хиалуронови филъри</strong> — Обемизиране и контуриране на устни, скули, назолабиални гънки. Незабавен ефект, естествен резултат.</li>
        <li><strong>Ботулинов токсин (Ботокс)</strong> — Премахване на бръчки в областта на челото, между веждите и около очите. Превантивна и корективна употреба.</li>
        <li><strong>Плазмолифтинг (PRP)</strong> — Лечение с богата на тромбоцити плазма. Подобрява качеството на кожата, стимулира колагена, естествено подмладяване.</li>
        <li><strong>Perioral Rejuvenation</strong> — Специализирани техники за подмладяване на областта около устата.</li>
      </ul>
      <div class="info-box">
        <h3>💆 Квалификации</h3>
        <p>Д-р Пенкова е преминала специализирано обучение по „Soft Tissue Restoration And Perioral Rejuvenation With HA Fillers" (2019). Всички процедури се извършват с сертифицирани материали.</p>
      </div>
    </article>
    <aside class="content-sidebar">
      <div class="sidebar-card" data-animate="fade-left"><h3>Запишете час</h3><p>Консултация за лицева естетика.</p><ContactForm lang={lang} /></div>
    </aside>
  </div></section>
</BaseLayout>
<style>
.page-hero{background:var(--color-dark);padding:clamp(6rem,12vw,10rem) 0 clamp(3rem,6vw,5rem)}.page-hero h1{color:var(--color-cream);margin-top:0.5rem}.hero-sub{color:rgba(250,247,242,0.6);font-size:1.1rem;margin-top:0.5rem}.content-grid{display:grid;grid-template-columns:1fr 380px;gap:4rem;align-items:start}.content-body h2{font-size:1.5rem;margin:2rem 0 0.75rem}.content-body p{color:var(--color-text-muted);line-height:1.8;margin-bottom:1rem}.service-list{padding-left:1.5rem;display:flex;flex-direction:column;gap:1rem;margin-block:1rem}.service-list li{color:var(--color-text-muted);line-height:1.7}.service-list strong{color:var(--color-dark)}.info-box{background:var(--color-cream-dark);border-left:3px solid var(--color-gold);border-radius:0 var(--radius-md) var(--radius-md) 0;padding:1.5rem;margin-top:2rem}.info-box h3{font-size:1.1rem;margin-bottom:0.5rem}.info-box p{margin:0;font-size:0.9rem}.sidebar-card{background:var(--color-white);border:1px solid var(--color-border);border-radius:var(--radius-md);padding:1.75rem}.sidebar-card h3{font-size:1.25rem;margin-bottom:0.5rem}.sidebar-card p{font-size:0.875rem;color:var(--color-text-muted);margin-bottom:1.25rem}
@media(max-width:900px){.content-grid{grid-template-columns:1fr}}
</style>
