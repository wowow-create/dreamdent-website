---
export const prerender = true;
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
const lang = 'bg';
---
<BaseLayout title="Други услуги — DreamDent Плевен">
  <div class="page-hero"><div class="container" data-animate="fade-up">
    <div class="breadcrumb"><a href="/">Начало</a><span class="breadcrumb-sep">/</span><span>Други услуги</span></div>
    <span class="section-label">Услуги</span><h1>Други услуги</h1>
    <p class="hero-sub">Пълен спектър от дентални грижи</p>
  </div></div>
  <section class="section"><div class="container content-grid">
    <article class="content-body" data-animate="fade-up">
      <h2>Допълнителни услуги</h2>
      <p>В DreamDent предлагаме пълен спектър от дентални услуги, насочени към здравето и естетиката на Вашите зъби.</p>
      <ul class="service-list">
        <li><strong>Лечение на кариес</strong> — Съвременни методи за лечение на кариес с минимален дискомфорт.</li>
        <li><strong>Детска стоматология</strong> — Специалистът работи с деца и създава положителни асоциации с денталния кабинет.</li>
        <li><strong>Ендодонтско лечение</strong> — Лечение на кореновите канали за запазване на зъба.</li>
        <li><strong>Протезиране</strong> — Снемаеми зъбни протези при необходимост.</li>
        <li><strong>Профилактика</strong> — Редовни прегледи и почистване за дългосрочно здраве на зъбите.</li>
      </ul>
      <div class="info-box">
        <h3>ℹ️ Запитване</h3>
        <p>За услуга, която не намирате в нашия списък, свържете се с нас — ще Ви насочим към най-подходящото решение.</p>
      </div>
    </article>
    <aside class="content-sidebar">
      <div class="sidebar-card" data-animate="fade-left"><h3>Запишете час</h3><p>Свържете се с нас за запитване.</p><ContactForm lang={lang} /></div>
    </aside>
  </div></section>
</BaseLayout>
<style>
.page-hero{background:var(--color-dark);padding:clamp(6rem,12vw,10rem) 0 clamp(3rem,6vw,5rem)}.page-hero h1{color:var(--color-cream);margin-top:0.5rem}.hero-sub{color:rgba(250,247,242,0.6);font-size:1.1rem;margin-top:0.5rem}.content-grid{display:grid;grid-template-columns:1fr 380px;gap:4rem;align-items:start}.content-body h2{font-size:1.5rem;margin:2rem 0 0.75rem}.content-body p{color:var(--color-text-muted);line-height:1.8;margin-bottom:1rem}.service-list{padding-left:1.5rem;display:flex;flex-direction:column;gap:1rem;margin-block:1rem}.service-list li{color:var(--color-text-muted);line-height:1.7}.service-list strong{color:var(--color-dark)}.info-box{background:var(--color-cream-dark);border-left:3px solid var(--color-gold);border-radius:0 var(--radius-md) var(--radius-md) 0;padding:1.5rem;margin-top:2rem}.info-box h3{font-size:1.1rem;margin-bottom:0.5rem}.info-box p{margin:0;font-size:0.9rem}.sidebar-card{background:var(--color-white);border:1px solid var(--color-border);border-radius:var(--radius-md);padding:1.75rem}.sidebar-card h3{font-size:1.25rem;margin-bottom:0.5rem}.sidebar-card p{font-size:0.875rem;color:var(--color-text-muted);margin-bottom:1.25rem}
@media(max-width:900px){.content-grid{grid-template-columns:1fr}}
</style>
